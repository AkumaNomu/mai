{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SceneSongRecommendations",
  "type": "object",
  "required": ["num_scenes", "library_size", "scenes"],
  "properties": {
    "num_scenes": { "type": "integer" },
    "library_size": { "type": "integer" },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scene_id", "context", "target", "genre_targets", "recommendations"],
        "properties": {
          "scene_id": { "type": "string" },
          "context": { "type": "string" },
          "target": { "type": "object" },
          "genre_targets": { "type": "object" },
          "recommendations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "title", "artist", "score", "audio_score", "genre_score"],
              "properties": {
                "path": { "type": "string" },
                "title": { "type": "string" },
                "artist": { "type": "string" },
                "score": { "type": "number" },
                "audio_score": { "type": "number" },
                "genre_score": { "type": "number" },
                "audio_genre_score": { "type": "number" },
                "matched_genres": { "type": "array", "items": { "type": "string" } },
                "spotify_genres": { "type": "array", "items": { "type": "string" } },
                "audio_features": {
                  "type": "object",
                  "properties": {
                    "segment_stats": { "type": "array" },
                    "loudness_lufs": { "type": "number" },
                    "harmonic_percussive_ratio": { "type": "number" },
                    "rhythm_complexity": { "type": "number" },
                    "timbral_stats": { "type": "object" },
                    "embedding_similarity": { "type": "number" }
                  }
                },
                "component_similarity": { "type": "object" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
