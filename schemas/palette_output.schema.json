{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PaletteOutput",
  "type": "object",
  "required": ["input", "num_images", "k"],
  "properties": {
    "input": { "type": "string" },
    "num_images": { "type": "integer" },
    "k": { "type": "integer" },
    "palette": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["hex", "rgb", "pct"],
        "properties": {
          "hex": { "type": "string" },
          "rgb": { "type": "array", "items": { "type": "integer" } },
          "pct": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "metrics": { "type": "object" },
    "windows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["window_index", "frame_start", "frame_end", "num_images", "palette", "metrics"],
        "properties": {
          "window_index": { "type": "integer" },
          "frame_start": { "type": "integer" },
          "frame_end": { "type": "integer" },
          "num_images": { "type": "integer" },
          "time_start_sec": { "type": "number" },
          "time_end_sec": { "type": "number" },
          "palette": { "$ref": "#/properties/palette" },
          "metrics": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
